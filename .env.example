# Claude Desktop Tauri - Environment Configuration
# Copy this file to .env and fill in your API keys

# API Server Configuration
VITE_API_BASE_URL=http://localhost:30085
VITE_WS_BASE_URL=http://localhost:30085

# Anthropic API (Claude models)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_BASE_URL=https://api.anthropic.com

# OpenAI API (GPT models)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com

# GitHub Token (for Copilot/Codeium)
GITHUB_TOKEN=your_github_token_here

# Note: Never commit .env to version control. The .env file is in .gitignore.
